            },
            "url": { "raw": "{{baseUrl}}/evaluation/submit", "host": ["{{baseUrl}}"], "path": ["evaluation", "submit"] }
          }
        },
        {
          "name": "GET Evaluation Result",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "url": { "raw": "{{baseUrl}}/evaluation/results/{{submissionId}}", "host": ["{{baseUrl}}"], "path": ["evaluation", "results", "{{submissionId}}"] }
          }
        },
        {
          "name": "GET Evaluation History",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "url": { "raw": "{{baseUrl}}/evaluation/history", "host": ["{{baseUrl}}"], "path": ["evaluation", "history"] }
          }
