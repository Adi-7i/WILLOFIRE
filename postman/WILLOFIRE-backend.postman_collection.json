{
  "info": {
    "_postman_id": "9c5b1d8b-5a1c-4a6c-95e8-9e66b61a0211",
    "name": "WILLOFIRE Backend API",
    "description": "Complete backend collection for WILLOFIRE NestJS API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "pdfId", "value": "" },
    { "key": "mcqTestId", "value": "" },
    { "key": "submissionId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] },
            "description": "Public health endpoint"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"StrongPass@123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const data = pm.response.json();",
                  "  if (data.accessToken) pm.collectionVariables.set('accessToken', data.accessToken);",
                  "  if (data.refreshToken) pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"StrongPass@123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "POST Refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const data = pm.response.json();",
                  "  if (data.accessToken) pm.collectionVariables.set('accessToken', data.accessToken);",
                  "  if (data.refreshToken) pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
          }
        },
        {
          "name": "POST Logout",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "PDF",
      "item": [
        {
          "name": "POST Upload PDF",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/pdf/upload", "host": ["{{baseUrl}}"], "path": ["pdf", "upload"] }
          }
        },
        {
          "name": "GET PDFs",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "url": { "raw": "{{baseUrl}}/pdf", "host": ["{{baseUrl}}"], "path": ["pdf"] }
          }
        },
        {
          "name": "GET PDF by Id",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "url": { "raw": "{{baseUrl}}/pdf/{{pdfId}}", "host": ["{{baseUrl}}"], "path": ["pdf", "{{pdfId}}"] }
          }
        }
      ]
    },
    {
      "name": "MCQ",
      "item": [
        {
          "name": "POST Generate MCQ",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pdfId\": \"{{pdfId}}\",\n  \"difficulty\": \"medium\",\n  \"count\": 10\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/mcq/generate", "host": ["{{baseUrl}}"], "path": ["mcq", "generate"] }
          }
        },
        {
          "name": "GET MCQ Tests",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "url": { "raw": "{{baseUrl}}/mcq", "host": ["{{baseUrl}}"], "path": ["mcq"] }
          }
        },
        {
          "name": "GET MCQ Test by Id",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "url": { "raw": "{{baseUrl}}/mcq/{{mcqTestId}}", "host": ["{{baseUrl}}"], "path": ["mcq", "{{mcqTestId}}"] }
          }
        },
        {
          "name": "POST Submit MCQ Attempt",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"answers\": [\n    { \"questionIndex\": 0, \"selectedOption\": 1 },\n    { \"questionIndex\": 1, \"selectedOption\": -1 }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/mcq/{{mcqTestId}}/submit", "host": ["{{baseUrl}}"], "path": ["mcq", "{{mcqTestId}}", "submit"] }
          }
        },
        {
          "name": "GET Download MCQ PDF",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "url": { "raw": "{{baseUrl}}/mcq/{{mcqTestId}}/download", "host": ["{{baseUrl}}"], "path": ["mcq", "{{mcqTestId}}", "download"] }
          }
        },
        {
          "name": "GET Download MCQ Answer Key",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "url": { "raw": "{{baseUrl}}/mcq/{{mcqTestId}}/download-answer-key", "host": ["{{baseUrl}}"], "path": ["mcq", "{{mcqTestId}}", "download-answer-key"] }
          }
        }
      ]
    },
    {
      "name": "Evaluation",
      "item": [
