# ──────────────────────────────────────────────────────
# Willofire – Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ──────────────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=3000
APP_NAME=Willofire
API_VERSION=v1

# MongoDB
MONGO_URI=mongodb://localhost:27017/willofire
DATABASE_NAME=WILLO

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRES_IN=7d

# ── LLM (Azure OpenAI — chat completions) ────────────────────────────────────
LLM_PROVIDER=azure
LLM_API_KEY=
LLM_AZURE_BASE_URL=https://<your-resource>.cognitiveservices.azure.com
LLM_AZURE_API_VERSION=2024-12-01-preview
LLM_AZURE_DEPLOYMENT=gpt-4.1

# ── Embedding (separate Azure OpenAI endpoint) ────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://<your-resource>.openai.azure.com/openai/v1
OPENAI_EMBED_MODEL=text-embedding-3-small
AI_MAX_CHUNKS=5

# Storage
STORAGE_PROVIDER=local

# Azure Blob Storage
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER_NAME=
BLOB_SAS_EXPIRY_HOURS=24
