# ──────────────────────────────────────────────────────
# Willofire – Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ──────────────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=3000
APP_NAME=Willofire
API_VERSION=v1

# MongoDB (configure in Phase 2)
MONGO_URI=mongodb://localhost:27017/willofire

# Redis (configure in Phase 2)
REDIS_HOST=redis-17386.c98.us-east-1-4.ec2.cloud.redislabs.com
REDIS_PORT=17386
REDIS_PASSWORD=

# JWT (configure in Phase 2)
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# AI Provider (configure in Phase 3)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AI_MAX_CHUNKS=5

# Storage (configure in Phase 2)
STORAGE_PROVIDER=local

# Azure Blob Storage
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER_NAME=
BLOB_SAS_EXPIRY_HOURS=24
