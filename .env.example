# ──────────────────────────────────────────────────────
# Willofire – Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ──────────────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=3000
APP_NAME=Willofire
API_VERSION=v1

# MongoDB (configure in Phase 2)
MONGO_URI=mongodb://localhost:27017/willofire

# Redis (configure in Phase 2)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (configure in Phase 2)
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# AI Provider (configure in Phase 3)
OPENAI_API_KEY=

# Storage (configure in Phase 2)
STORAGE_PROVIDER=local
